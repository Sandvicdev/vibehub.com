<%- include('partials/header') %>

<div class="max-w-6xl mx-auto px-4 py-10">

  <!-- BAŞLIK + ARAMA -->
  <div class="mb-8">
    <h1 class="font-display font-extrabold text-3xl mb-2">
      Playlist Keşfet
      <% if (query) { %><span class="text-primary text-xl font-bold ml-2">/ "<%= query %>"</span><% } %>
    </h1>
    <form action="/explore" method="GET" class="flex gap-2 mt-4 max-w-lg">
      <input
        name="q"
        value="<%= query %>"
        type="text"
        placeholder="Yeni vibe ara..."
        class="flex-1 bg-card border border-border rounded-full px-5 py-2.5 text-sm text-gray-200 placeholder-gray-600 outline-none focus:border-primary transition-colors"
      />
      <button type="submit" class="bg-primary hover:bg-blue-500 text-white px-5 py-2.5 rounded-full text-sm font-medium transition-colors">Ara</button>
    </form>
  </div>

  <!-- VIBE FİLTRE BARLARI -->
  <div class="flex flex-wrap gap-2 mb-8">
    <% ['trending','chill','hype','night','morning','sad','workout','party','focus','lofi'].forEach(v => { %>
      <a
        href="/explore?q=<%= v %>"
        class="<%= query === v ? 'bg-primary/20 border-primary text-primary' : 'bg-card border-border text-muted hover:text-primary hover:border-primary' %> border text-xs px-3 py-1.5 rounded-full transition-colors"
      ><%= v %></a>
    <% }) %>
  </div>

  <!-- PLAYLIST GRID -->
  <% if (playlists && playlists.length > 0) { %>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      <% playlists.forEach(p => { %>
        <a href="/playlist/<%= p.id %>" class="block bg-card border border-border rounded-2xl overflow-hidden card-hover">
          <!-- Kapak resmi -->
          <div class="relative aspect-square bg-border/30">
            <% if (p.image) { %>
              <img src="<%= p.image %>" alt="<%= p.name %>" class="w-full h-full object-cover" />
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center text-5xl">🎵</div>
            <% } %>
            <!-- Save Rate rozeti -->
            <div class="absolute top-2 right-2 bg-accent text-bg text-xs font-bold px-2 py-0.5 rounded-full">
              <%= p.save_rate %>%
            </div>
          </div>

          <div class="p-3">
            <div class="font-display font-bold text-sm truncate mb-0.5"><%= p.name %></div>
            <div class="text-xs text-muted truncate mb-2">by <%= p.owner %></div>

            <!-- Save bar -->
            <div class="h-1 bg-border rounded-full overflow-hidden mb-2">
              <div class="h-full bg-accent rounded-full save-bar-fill" style="width: <%= p.save_rate %>%"></div>
            </div>

            <div class="flex items-center justify-between text-xs text-muted">
              <span><%= p.track_count %> şarkı</span>
              <span class="text-primary"><%= (p.followers || 0).toLocaleString('tr-TR') %> takipçi</span>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <div class="text-center py-20 text-muted">
      <div class="text-5xl mb-4">🔍</div>
      <div class="font-display font-bold text-xl mb-2">Sonuç Bulunamadı</div>
      <p class="text-sm">Farklı bir arama terimi veya vibe dene.</p>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
